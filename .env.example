# Copy this file to .env before customizing local Docker settings:
#   Copy-Item .env.example .env

TZ=Asia/Seoul
DETECTBOT_CONFIG_FILE=/app/detectbot_portal/config/settings.docker.yaml

# Default mode: SQLite with Docker volume persistence.
DETECTBOT_DATABASE_BACKEND=sqlite
DETECTBOT_SQLITE_PATH=/app/detectbot_portal/data/detectbot_portal.sqlite3
DETECTBOT_REPORTS_DIR=/app/detectbot_portal/data/reports
DETECTBOT_AUTO_SEED_DEMO_DATA=true
DETECTBOT_MAX_UPLOAD_SIZE_MB=10

# Optional initial admin account. Replace before use.
DETECTBOT_ADMIN_USERNAME=admin
DETECTBOT_ADMIN_PASSWORD=ChangeMe123!

# Optional Fernet key for encrypted settings values. Keep this stable after first use.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DETECTBOT_SETTINGS_ENCRYPTION_KEY=

# PostgreSQL mode. Set DETECTBOT_DATABASE_BACKEND=postgresql and run the postgres profile.
DETECTBOT_POSTGRES_HOST=postgres
DETECTBOT_POSTGRES_PORT=5432
DETECTBOT_POSTGRES_DB=detectbot_portal
DETECTBOT_POSTGRES_USER=detectbot
DETECTBOT_POSTGRES_PASSWORD=ChangeMe123!
DETECTBOT_POSTGRES_POOL_PRE_PING=true
DETECTBOT_POSTGRES_POOL_SIZE=5
DETECTBOT_POSTGRES_MAX_OVERFLOW=10
